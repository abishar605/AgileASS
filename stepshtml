☸️ STEP 4: Create deployment.yaml
Create file → deployment.yaml
Paste:
apiVersion: apps/v1
kind: Deployment
metadata:
  name: html-demo
spec:
  replicas: 2
  selector:
    matchLabels:
      app: html-demo
  template:
    metadata:
      labels:
        app: html-demo
    spec:
      containers:
      - name: html-demo
        image: YOUR_DOCKERHUB_USERNAME/html-demo:latest
        ports:
        - containerPort: 80

---
apiVersion: v1
kind: Service
metadata:
  name: html-demo-service
spec:
  type: NodePort
  selector:
    app: html-demo
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30010

